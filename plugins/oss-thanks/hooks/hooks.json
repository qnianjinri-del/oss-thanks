{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/oss-thanks-hook.sh",
            "statusMessage": "Recording actual GitHub repo use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/oss-thanks-review.sh",
            "statusMessage": "Showing OSS Thanks review queue"
          }
        ]
      }
    ]
  }
}
