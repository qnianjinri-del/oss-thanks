{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/hooks/codex-post-tool-use.sh\"",
            "statusMessage": "Recording open-source references"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/oss_thanks.py\" review",
            "statusMessage": "Preparing open-source thanks queue"
          }
        ]
      }
    ]
  }
}
